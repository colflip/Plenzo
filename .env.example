# ===========================================
# 数据库配置 (Database)
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/schedule_db
DB_DRIVER=neon
DB_SSL=true
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=10000
DB_FETCH_TIMEOUT=10000
DB_MAX_RETRIES=5
DB_RETRY_DELAY=1000

# ===========================================
# 服务器配置 (Server)
# ===========================================
PORT=3002
NODE_ENV=development

# ===========================================
# JWT 认证 (Authentication)
# ===========================================
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REMEMBER_EXPIRES_IN=30d
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_REMEMBER_EXPIRES_IN=30d

# ===========================================
# 安全配置 (Security)
# ===========================================
REQUIRE_STRONG_PASSWORD=true

# 速率限制 (Rate Limiting)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5

# ===========================================
# 开发模式 (Development)
# ===========================================
OFFLINE_DEV=false
DEBUG_AUDIT=false

# ===========================================
# AI 功能配置 (AI Features)
# ===========================================
# 总开关：启用 AI 助手功能
AI_ENABLED=true

# 当前使用的 AI 模型配置
AI_PROVIDER=mistral                          # 服务商标识
AI_PROTOCOL=openai                           # 协议：openai | messages
AI_API_KEY=your_api_key_here                 # API 密钥
AI_BASE_URL=https://api.mistral.ai/v1        # API 地址
AI_MODEL=mistral-small-latest                # 模型 ID
AI_TIMEOUT=30000                             # 超时时间（毫秒）
AI_MAX_TOKENS=3000                           # 最大生成 tokens

# -------------------------------------------
# 预设模型 1: Mistral AI
# -------------------------------------------
LLM_API_KEY=your_mistral_key
LLM_BASE_URL=https://api.mistral.ai/v1
LLM_MODEL=mistral-small-latest
LLM_LABEL=Mistral Small

# -------------------------------------------
# 预设模型 2: Agnes AI
# -------------------------------------------
LLM_ALT_API_KEY=your_agnes_key
LLM_ALT_BASE_URL=https://apihub.agnes-ai.com/v1
LLM_ALT_MODEL=agnes-2.0-flash
LLM_ALT_LABEL=Agnes AI

# ===========================================
# 平台检测 (Platform Detection)
# ===========================================
# 以下变量由部署平台自动设置，无需手动配置
# VERCEL=1
# RENDER=true
